# ── Server-only secrets (never expose to the browser) ──────────────────────────

# Resend (transactional email)
RESEND_API_KEY=re_xxx

# Telegram bot (admin notifications + chat reply webhook)
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=0000000000

# Neon PostgreSQL (used by @neondatabase/serverless)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Bearer token to authorize admin-only endpoints (e.g. GET /api/contact).
# Generate a long random string: `openssl rand -hex 32`
ADMIN_TOKEN=replace-with-openssl-rand-hex-32

# Comma-separated list of allowed dev origins for `next dev` LAN access.
# Leave empty in production.
DEV_ORIGINS=http://192.168.0.197:3000,192.168.0.197
